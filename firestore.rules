rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /cms_pages/{pageId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /cms_settings/{docId} {
      allow read: if true;
      allow write: if isSignedIn() && docId == 'global';
    }

    // Media library — https paths or base64 image data URLs
    match /media/{mediaId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Legacy collection (migrate to `media`, then remove)
    match /cms_media/{mediaId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
