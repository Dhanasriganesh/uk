# Copy to .env and fill with your Firebase project credentials
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# CLI seed (npm run seed:local) — Firebase Auth admin user
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Vercel — live admin uploads via public Blob store "ats-medias"
# Auto-set when store is connected: BLOB_STORE_ID, VERCEL_OIDC_TOKEN, BLOB_WEBHOOK_PUBLIC_KEY
# If OIDC uploads fail, copy Read-Write Token from Storage → ats-medias and add:
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Optional fallback — Firebase Storage uploads (requires Blaze plan)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_STORAGE_BUCKET=
