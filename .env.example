# Copy to .env and fill with your Firebase project credentials
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# CLI seed (npm run seed:local) — Firebase Auth admin user
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Vercel — live admin uploads via public Blob store "ats-medias"
# Run: vercel link && vercel env pull   (creates .env.local with blob token)
# Local dev uses the same Blob storage when BLOB_READ_WRITE_TOKEN is present.
# Without it, uploads go to public/media/ and ONLY work on localhost — not on Vercel.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Optional fallback — Firebase Storage uploads (requires Blaze plan)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_STORAGE_BUCKET=
